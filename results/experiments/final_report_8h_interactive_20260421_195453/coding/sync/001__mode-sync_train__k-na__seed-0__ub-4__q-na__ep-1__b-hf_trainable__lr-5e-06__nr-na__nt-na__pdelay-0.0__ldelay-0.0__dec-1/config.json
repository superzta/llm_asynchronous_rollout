{
  "mode": "sync_train",
  "dataset": "data/tiny_coding_train.jsonl",
  "seed": 0,
  "update_batch_size": 4,
  "epochs": 1,
  "backend": "hf_trainable",
  "lr": 5e-06,
  "max_new_tokens": 96,
  "reward_timeout_sec": 2.0,
  "hf_model_id": "Qwen/Qwen2.5-0.5B-Instruct",
  "hf_dtype": "float32",
  "hf_attn_impl": "eager",
  "hf_chat_template": 1,
  "grpo_epsilon": 0.2,
  "grpo_kl_coef": 0.02,
  "grpo_group_size": 0,
  "grad_clip": 1.0,
  "weight_decay": 0.0,
  "temperature": 0.9,
  "top_p": 0.95,
  "device": "auto",
  "decoupled_objective": 1
}