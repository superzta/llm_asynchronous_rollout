# ---- Python / caches ----------------------------------------------------
# Note: files listed here are ignored only if not already tracked. Remove
# stray bytecode from the index with: git rm -r --cached '**/__pycache__'
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyw
*.pyz
*.pywz
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Virtualenvs / package managers ------------------------------------
.venv/
venv/
env/
.env
.python-version
uv.lock.local
.uv_cache/

# ---- Editor / OS ---------------------------------------------------------
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*.bak

# ---- Experiment outputs -------------------------------------------------
# Ignore all of results/ except the curated paper snapshot (repro bundle).
results/*
!results/experiments/
results/experiments/*
!results/experiments/final_report_8h_interactive_20260421_195453/
!results/experiments/final_report_8h_interactive_20260421_195453/**

results_*/
experiments/
logs/
runs/
wandb/
tensorboard/

# ---- Model / dataset caches --------------------------------------------
checkpoints/
huggingface_cache/
hf_cache/
.cache/
triton_cache/
inductor_cache/

# ---- Generated artifacts ------------------------------------------------
*.pt
*.bin
*.safetensors
*.npy
*.npz
*.pkl
*.pickle

# ---- Plot / analysis outputs (global) -----------------------------------
*.png
*.pdf
!docs/**/*.png
!docs/**/*.pdf

# Curated snapshot may include paper figures (override globals above).
!results/experiments/final_report_8h_interactive_20260421_195453/**/*.png
!results/experiments/final_report_8h_interactive_20260421_195453/**/*.pdf

*.log
!results/experiments/final_report_8h_interactive_20260421_195453/**/*.log

